# ==========================================================================
#  Пример конфигурации. Скопируй в .env и подставь свои значения:
#    cp .env.example .env
#  Файл .env в git не коммитится (см. .gitignore).
# ==========================================================================

# --- Приложение ---
APP_ENV=development            # development | production
APP_NAME="Dev Landing API"
APP_VERSION=1.0.0
HOST=0.0.0.0
PORT=8000

# --- CORS ---
# Через запятую. Для локалки достаточно localhost, в проде — домен фронта.
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:8000

# --- База данных ---
# Если пусто — поднимется локальный SQLite (./data/app.db), удобно для разработки.
# Для PostgreSQL формат:
#   postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=

# --- AI (Anthropic / Claude) ---
# Если ключ пустой — сервис автоматически переходит на эвристический fallback.
ANTHROPIC_API_KEY=
AI_MODEL=claude-haiku-4-5
AI_TIMEOUT_SECONDS=12
AI_MAX_TOKENS=1024

# --- Почта (SMTP) ---
# По умолчанию настроено под Mailtrap sandbox (письма не уходят реальным людям).
# Если SMTP_HOST пустой — письма пишутся в лог (console transport), сервис не падает.
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
MAIL_FROM="Dev Landing <no-reply@devlanding.local>"
OWNER_EMAIL=elijafarafonov@gmail.com

# --- Rate limiting ---
# Сколько обращений с одного IP разрешено за окно (в секундах).
RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_WINDOW_SECONDS=3600

# --- Логирование ---
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
LOG_FILE=logs/app.log
